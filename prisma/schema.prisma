generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  password          String
  firstName         String
  lastName          String
  role              Role              @default(USER)
  status            UserStatus        @default(ACTIVE)
  profileImage      String?
  collegeId         String?
  emailVerified     Boolean           @default(false)
  isActive          Boolean           @default(true)
  isProfileComplete Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  lastLoginAt       DateTime?
  college           College?          @relation(fields: [collegeId], references: [id])
  organizerRequest  OrganizerRequest?
  profile           Profile?

  @@index([email])
  @@index([role])
  @@index([collegeId])
  @@map("users")
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  firstName    String
  lastName     String
  whatsapp     String
  gender       String?
  dateOfBirth  DateTime
  college      String
  year         Int
  branch       Branch
  customBranch String?
  collegeId    String
  city         String
  state        String
  country      String
  profilePhoto String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model OrganizerRequest {
  id               String   @id @default(uuid())
  userId           String   @unique
  organizationName String
  website          String?
  contactNumber    String
  reason           String
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("organizer_requests")
}

model College {
  id        String   @id @default(uuid())
  name      String   @unique
  domain    String?  @unique
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@index([name])
  @@index([domain])
  @@map("colleges")
}

model AdminRequest {
  id           String             @id @default(uuid())
  collegeName  String
  firstName    String             @default("Admin")
  email        String             @unique
  passwordHash String?
  status       AdminRequestStatus @default(PENDING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([status])
  @@index([email])
  @@map("admin_requests")
}

enum Role {
  SUPERADMIN
  ADMIN
  ORGANIZER
  USER
}

enum UserStatus {
  ACTIVE
  PENDING
  REJECTED
  SUSPENDED
}

enum AdminRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Branch {
  CSE
  ECE
  EEE
  MECH
  CIVIL
  IT
  AIDS
  AIML
  BBA
  BCA
  MBA
  MCA
  OTHER
}